FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy application code
COPY index.ts tsconfig.json.mcp ./

# Copy the MCP specific tsconfig
RUN mv tsconfig.json.mcp tsconfig.json

# Build the application
RUN npm run build

# Command will be provided by smithery.yaml
CMD ["node", "dist/index.js"]