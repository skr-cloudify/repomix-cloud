{
  "name": "repo-to-file-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for converting repositories to files for LLM consumption with private repository support",
  "type": "module",
  "module": "smithery-entry.cjs",
  "main": "lib/src/index.js",
  "bin": {
    "repo-to-file-mcp": "./lib/src/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('lib/src/index.js', '755')\"",
    "smithery-build": "npx @smithery/cli build",
    "prepare": "npm run build",
    "start": "node lib/src/index.js"
  },
  "dependencies": {
    "@clack/prompts": "^0.6.3",
    "@modelcontextprotocol/sdk": "^1.17.3",
    "cli-spinners": "^3.2.1",
    "globby": "^13.1.4",
    "log-update": "^5.0.1",
    "picocolors": "^1.0.0",
    "piscina": "^5.1.3",
    "repomix": "^0.3.5",
    "strip-comments": "^2.0.1",
    "zod": "^3.25.46"
  },
  "devDependencies": {
    "@smithery/cli": "^1.0.0",
    "@types/node": "^22.14.1",
    "tsx": "^4.16.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "ai",
    "claude",
    "repomix",
    "codebase"
  ],
  "author": "",
  "license": "MIT"
}
