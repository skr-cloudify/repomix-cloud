    ));
    assert!(matches!(
        OffsetDateTime::parse("2021-01-01T00:00:00+00:60", &Rfc3339),
        Err(error::Parse::TryFromParsed(error::TryFromParsed::ComponentRange(component))) if component.name() == "offset minute"
    ));
    assert!(matches!(
