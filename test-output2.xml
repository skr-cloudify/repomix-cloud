    // even if the input could refer to one.
    assert!(matches!(
        PrimitiveDateTime::parse("2022-01-01T00:59:60+01:00", &Rfc3339),
        Err(error::Parse::TryFromParsed(error::TryFromParsed::ComponentRange(component))) if component.name() == "second"
    ));
