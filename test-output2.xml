    let value = TestBadIo {
        dt: datetime!(2000-01-01 00:00 -4:00),
    };
    assert_ser_tokens_error::<TestBadIo>(
        &value,
        &[
            Token::Struct {
                name: "TestBadIo",
                len: 1,
            },
            Token::Str("dt"),
        ],
        "failed to write whole buffer",
    );
}
