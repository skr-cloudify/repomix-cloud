#[test]
fn to_offset() {
    assert_eq!(
        utc_datetime!(2000-01-01 0:00).to_offset(offset!(-1)),
        datetime!(1999-12-31 23:00 -1),
    );
    assert_eq!(
        utc_datetime!(0000-001 0:00).to_offset(offset!(UTC)),
        datetime!(0000-001 0:00 UTC),
    );
}

#[test]
