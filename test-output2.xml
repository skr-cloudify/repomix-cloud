    assert_size!(error::ComponentRange, 56, 56);
    assert_size!(error::ConversionRange, 0, 1);
    assert_size!(error::DifferentVariant, 0, 1);
    assert_size!(error::IndeterminateOffset, 0, 1);
    assert_size!(modifier::Day, 1, 1);
